# ============================================
# Shin Proxy Configuration
# ============================================

# Server Configuration
HOST=0.0.0.0
PORT=4000

# Auth — API key for clients to authenticate with this proxy
LITELLM_MASTER_KEY=sk-local-dev

# Cursor API Configuration
CURSOR_BASE_URL=https://cursor.com
CURSOR_MODEL=anthropic/claude-sonnet-4.6

# Cursor Authentication (REQUIRED)
# Get from browser DevTools -> Application -> Cookies or Headers
CURSOR_COOKIE=WorkosCursorSessionToken=user_01K3G1E6HH9MNC32TG6GF5GB9V::eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..7RuLnTJ8KgXvz2pk7PfRM0D3jCvRoRDBAGshpe5ZJLc
CURSOR_COOKIES=WorkosCursorSessionToken=user_01K3G1E6HH9MNC32TG6GF5GB9V::eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..7RuLnTJ8KgXvz2pk7PfRM0D3jCvRoRDBAGshpe5ZJLc
CURSOR_AUTH_HEADER=

# Context Configuration
CURSOR_CONTEXT_FILE_PATH=/docs/

# Retry Configuration
GATEWAY_RETRY_ATTEMPTS=2
GATEWAY_RETRY_BACKOFF_SECONDS=0.6

# Adaptive concurrency (upstream protection)
GATEWAY_ADAPTIVE_CONCURRENCY_ENABLED=true
GATEWAY_ADAPTIVE_CONCURRENCY_INITIAL=21
GATEWAY_ADAPTIVE_CONCURRENCY_MIN=21
GATEWAY_ADAPTIVE_CONCURRENCY_MAX=21
GATEWAY_ADAPTIVE_CONCURRENCY_SUCCESS_WINDOW=8
GATEWAY_ADAPTIVE_CONCURRENCY_RATE_LIMIT_COOLDOWN_SECONDS=6

# Cache Configuration
GATEWAY_CACHE_ENABLED=true
GATEWAY_CACHE_TTL_SECONDS=45
GATEWAY_CACHE_MAX_ENTRIES=500

# Pricing (per 1K tokens)
GATEWAY_PRICE_ANTHROPIC_PER_1K=0.015
GATEWAY_PRICE_OPENAI_PER_1K=0.01

# Optional: User-Agent for requests
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/137.0.0.0 Safari/537.36

